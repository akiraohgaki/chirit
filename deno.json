{
  "name": "@akiraohgaki/chirit",
  "version": "1.13.3",
  "exports": {
    ".": "./mod.ts",
    "./util": "./util.ts"
  },
  "publish": {
    "include": [
      "src/**/*.ts",
      "mod.ts",
      "util.ts",
      "deno.json",
      "README.md",
      "LICENSE"
    ]
  },
  "compilerOptions": {
    "lib": [
      "deno.ns",
      "esnext",
      "dom",
      "dom.iterable",
      "dom.asynciterable"
    ],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true
  },
  "lint": {
    "include": [
      "src/",
      "tests/",
      "*.ts"
    ],
    "rules": {
      "tags": [
        "recommended"
      ],
      "include": [
        "explicit-module-boundary-types"
      ],
      "exclude": [
        "no-inferrable-types"
      ]
    }
  },
  "fmt": {
    "include": [
      "src/",
      "tests/",
      "*.ts",
      "*.json",
      "*.md"
    ],
    "useTabs": false,
    "lineWidth": 120,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": true,
    "proseWrap": "preserve"
  },
  "test": {
    "include": [
      "tests/unit/"
    ]
  },
  "tasks": {
    "install": "deno task install:pre && deno task install:install && deno task install:post",
    "install:pre": "echo 'Skip task install:pre'",
    "install:install": "deno install",
    "install:post": "deno run -A npm:playwright install --with-deps",
    "check": "deno task check:pre && deno task check:check && deno task check:post",
    "check:pre": "deno outdated && deno fmt && deno lint",
    "check:check": "deno check src/ tests/ *.ts",
    "check:post": "echo 'Skip task check:post'",
    "build": "deno task build:pre && deno task build:build && deno task build:post",
    "build:pre": "echo 'Skip task build:pre'",
    "build:build": "deno run -A jsr:@akiraohgaki/devsrv/bundle --minify=true mod.ts mod.bundle.js",
    "build:post": "echo 'Skip task build:post'",
    "test": "deno task test:pre && deno task test:unit && deno task test:e2e && deno task test:post",
    "test:pre": "echo 'Skip task test:pre'",
    "test:unit": "deno test -A --coverage",
    "test:e2e": "deno run -A npm:playwright test",
    "test:post": "echo 'Skip task test:post'",
    "serve": "deno run -A jsr:@akiraohgaki/devsrv/serve tests/playground"
  },
  "imports": {
    "@akiraohgaki/devsrv": "jsr:@akiraohgaki/devsrv@^0.11.0",
    "@playwright/test": "npm:@playwright/test@^1.58.2",
    "@std/assert": "jsr:@std/assert@^1.0.19"
  },
  "nodeModulesDir": "auto"
}
